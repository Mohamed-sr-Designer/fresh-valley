# ── Fresh Valley API — environment ────────────────────────────────
# Copy this file to `.env` and fill in real values before deploying.
# NEVER commit the real .env (it is git-ignored).

# Port the server listens on
PORT=4000

# Public origin of the storefront (used for CORS). Comma-separate multiple.
# In production set this to your real domain, e.g. https://freshvalley.eg
CORS_ORIGIN=http://localhost:4000

# Secret used to sign JWT access tokens. MUST be a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
# How long an admin session token stays valid
JWT_EXPIRES=7d

# The first Super Admin, created on first run (change immediately after).
SEED_ADMIN_NAME=Mohamed Tarek
SEED_ADMIN_EMAIL=admin@freshvalley.eg
SEED_ADMIN_PASSWORD=change-this-strong-password

# Seed realistic demo orders/customers on first run? (true for staging, false for production)
SEED_DEMO=true

# Where the SQLite database file lives (relative to /server, or an absolute path)
DB_FILE=./data/fresh-valley.db

# Max upload size for banner images, in megabytes
MAX_UPLOAD_MB=3
